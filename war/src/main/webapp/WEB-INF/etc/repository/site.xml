<?xml version="1.0" encoding="UTF-8"?>
<site jcr:primaryType="jnt:virtualsite"
      xmlns:jcr="http://www.jcp.org/jcr/1.0"
      xmlns:j="http://www.jahia.org/jahia/1.0"
      xmlns:jnt="http://www.jahia.org/jahia/nt/1.0">

    <files jcr:primaryType="jnt:folder">
    </files>

    <users jcr:primaryType="jnt:usersFolder">
        <j:acl j:inherit="false"
               jcr:primaryType="jnt:acl">
            <GRANT_g_users j:protected="false" j:principal="g:users" j:roles="reader" j:aceType="GRANT"
                           jcr:primaryType="jnt:ace"/>
            <GRANT_g_privileged j:protected="false" j:principal="g:privileged" j:roles="privileged" j:aceType="GRANT"
                                jcr:primaryType="jnt:ace"/>
            <GRANT_g_site-administrators j:aceType="GRANT"
                                         j:principal="g:site-administrators"
                                         j:protected="false"
                                         j:roles="site-administrator"
                                         jcr:primaryType="jnt:ace"/>
            <GRANT_g_site-privileged j:protected="false" j:principal="g:site-privileged" j:roles="privileged" j:aceType="GRANT"
                                     jcr:primaryType="jnt:ace"/>
        </j:acl>
    </users>

    <groups jcr:primaryType="jnt:groupsFolder">
        <site-users jcr:primaryType="jnt:group" jcr:mixinTypes="jmix:systemNode" j:hidden="false">
            <j:members jcr:primaryType="jnt:members"/>
        </site-users>
        <site-administrators jcr:primaryType="jnt:group" jcr:mixinTypes="jmix:systemNode" j:hidden="false">
            <j:members jcr:primaryType="jnt:members"/>
        </site-administrators>
        <site-privileged jcr:primaryType="jnt:group" jcr:mixinTypes="jmix:systemNode" j:hidden="false">
            <j:members jcr:primaryType="jnt:members"/>
        </site-privileged>
        <j:acl j:inherit="false"
               jcr:primaryType="jnt:acl">
            <GRANT_g_users j:protected="false" j:principal="g:users" j:roles="reader" j:aceType="GRANT"
                           jcr:primaryType="jnt:ace"/>
            <GRANT_g_privileged j:protected="false" j:principal="g:privileged" j:roles="privileged" j:aceType="GRANT"
                                jcr:primaryType="jnt:ace"/>
            <GRANT_g_site-administrators j:aceType="GRANT"
                                         j:principal="g:site-administrators"
                                         j:protected="false"
                                         j:roles="site-administrator"
                                         jcr:primaryType="jnt:ace"/>
            <GRANT_g_site-privileged j:protected="false" j:principal="g:site-privileged" j:roles="privileged" j:aceType="GRANT"
                                     jcr:primaryType="jnt:ace"/>
        </j:acl>
    </groups>

    <contents jcr:primaryType="jnt:contentFolder"/>

</site>
